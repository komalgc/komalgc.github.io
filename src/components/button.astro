---
type Variant = "default" | "aqua";

const { link, text, variant = "default" } = Astro.props as {
  link: string;
  text: string;
  variant?: Variant;
};

const base =
  "inline-flex w-auto px-4 py-2 mt-5 text-xs font-semibold duration-300 ease-out border rounded-full";

const variants: Record<Variant, string> = {
  default:
    "bg-neutral-900 dark:bg-white dark:text-neutral-900 text-neutral-100 hover:border-neutral-700 border-neutral-900 dark:hover:border-neutral-300 hover:bg-white dark:hover:bg-black dark:hover:text-white hover:text-neutral-900",
  aqua:
    "bg-cyan-400 text-neutral-900 border-cyan-400 hover:bg-cyan-500 hover:border-cyan-500 hover:text-neutral-900",
};
---

<a href={link} class={`${base} ${variants[variant] ?? variants.default}`}>
  {text}
</a>